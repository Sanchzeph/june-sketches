<script>
function go(tab, el) {
  document.querySelectorAll('.tile').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('on'));
  document.getElementById('screen-' + tab).classList.add('on');
}
function toggle(n) {
  const ep = document.getElementById('ep-' + n);
  const ch = document.getElementById('ch-' + n);
  const rw = document.getElementById('rw-' + n);
  const open = ep && ep.style.display !== 'none';
  if (ep) ep.style.display = open ? 'none' : 'block';
  if (ch) ch.classList.toggle('open', !open);
  if (rw) rw.classList.toggle('accent-red', !open);
}
// Start with row 1 expanded
document.getElementById('ep-1').style.display = 'block';
</script>
